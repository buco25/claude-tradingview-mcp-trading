// ══════════════════════════════════════════════════════════════════════════════
// SYNAPSE-7 Strategy
// Kombinira 5 sustava:
//   1. AI kNN Prediction       (Zeiierman — AI Predictive Flow)
//   2. AutoTune Filter         (Ehlers — TASC May 2026)
//   3. 6-Scale EMA Consensus   (SmartTrader EP06 — trend bias)
//   4. RSI Momentum            (Pumori / Carrrir)
//   5. CVD Delta               (CVDProfiles + FocusBars — volume pressure)
//
// SL 2% / TP 4% / R:R 1:2 | Notional 50% equity (= 2% margin × 25x)
// ══════════════════════════════════════════════════════════════════════════════
//@version=6
strategy(
    title                   = "SYNAPSE-7 [AI·Ehlers·Trend·RSI·CVD]",
    shorttitle              = "SYN-7",
    overlay                 = false,
    initial_capital         = 1000,
    default_qty_type        = strategy.percent_of_equity,
    default_qty_value       = 50,
    commission_type         = strategy.commission.percent,
    commission_value        = 0.05,
    slippage                = 2,
    calc_on_every_tick      = false,
    process_orders_on_close = true
)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════

// 1 — AI kNN
kLen   = input.int(10, "Pattern Length",      minval=5,         group="🤖 AI kNN")
kMem   = input.int(20, "Memory Size",         minval=10,        group="🤖 AI kNN")
kK     = input.int(5,  "Neighbours",          minval=1, maxval=20, group="🤖 AI kNN")
kSmth  = input.int(5,  "Prediction Smooth",   minval=1,         group="🤖 AI kNN")
kSigLn = input.int(5,  "Signal Length",       minval=1,         group="🤖 AI kNN")

// 2 — AutoTune
atWin  = input.int(20, "AutoTune Window",     minval=3,         group="📡 AutoTune (Ehlers)")

// 3 — 6-Scale EMA Consensus
yzMin  = input.int(3,  "Consensus Min (1–6)", minval=1, maxval=6, group="📐 6-Scale Trend")

// 4 — RSI
rsiLen = input.int(14, "RSI Length",                            group="📊 RSI Pumori")
rsiMaL = input.int(14, "RSI MA Length",                         group="📊 RSI Pumori")

// 5 — CVD
cvdLen = input.int(20, "CVD Period",          minval=5,         group="📦 CVD Delta")

// Combination
minSig = input.int(3,  "Min Signals (1–5)",   minval=1, maxval=5, group="🎯 Combination")

// Risk
slPct  = input.float(2.0, "SL %", minval=0.5, step=0.5,        group="⚡ Risk")
tpPct  = input.float(4.0, "TP %", minval=0.5, step=0.5,        group="⚡ Risk")

// ══════════════════════════════════════════════════════════════════════════════
// 1. AI kNN PREDICTION (Zeiierman — AI Predictive Flow)
// ══════════════════════════════════════════════════════════════════════════════

var kY  = array.new<float>()
var kM1 = matrix.new<float>()
var kM2 = matrix.new<float>()
var kM3 = matrix.new<float>()
var kM4 = matrix.new<float>()
var kF1 = matrix.new<float>()
var kF2 = matrix.new<float>()
var kF3 = matrix.new<float>()
var kF4 = matrix.new<float>()
var kDs = array.new<float>()

var float kPred   = na
var float kPredSm = na
var bool  kUp     = false

_emaLn = 14
_fLen  = 10
_sLen  = 30
_rLn   = 14
_momLn = 5
_atrLn = 100
_bMult = 2.0
_regLn = 30
_oscLn = 3
_ahead = 2

kBase = ta.ema(close, _emaLn)
kAtr  = ta.atr(_atrLn)
kTot  = kLen + _ahead
kRdy  = bar_index > kTot + math.max(_momLn, _sLen) + _ahead + 5

feat(sh, m) =>
    c  = close[sh]
    c1 = close[sh + 1]
    cm = close[sh + _momLn]
    ef = ta.ema(close, _fLen)[sh]
    es = ta.ema(close, _sLen)[sh]
    r  = ta.rsi(close, _rLn)[sh]
    float v = 0.0
    if m == 1
        v := c1 != 0 ? math.log(c / c1) : 0.0
    else if m == 2
        v := cm != 0 ? (c - cm) / cm : 0.0
    else if m == 3
        v := (r - 50.0) / 50.0
    else
        v := c != 0 ? (ef - es) / c : 0.0
    v

pushFeat(mat, m) =>
    vals = array.new<float>(kTot, 0.0)
    for i = 0 to kTot - 1
        vals.set(kTot - 1 - i, feat(i, m))
    cur = vals.slice(kTot - kLen, kTot)
    old = vals.slice(0, kLen)
    out = matrix.new<float>(1, kLen, 0.0)
    for i = 0 to kLen - 1
        out.set(0, i, cur.get(i))
    h = array.new<float>(kLen, 0.0)
    for i = 0 to kLen - 1
        h.set(i, old.get(i))
    if mat.rows() >= kMem
        mat.remove_row(0)
    mat.add_row(mat.rows(), h)
    out

getDist(a1, a2, a3, a4, b1, b2, b3, b4) =>
    out = array.new<float>(b1.rows(), 0.0)
    for i = 0 to b1.rows() - 1
        s  = 0.0
        d1 = a1.diff(b1.submatrix(i, i + 1)).row(0)
        d2 = a2.diff(b2.submatrix(i, i + 1)).row(0)
        d3 = a3.diff(b3.submatrix(i, i + 1)).row(0)
        d4 = a4.diff(b4.submatrix(i, i + 1)).row(0)
        for j = 0 to kLen - 1
            s += (math.pow(d1.get(j), 2) + math.pow(d2.get(j), 2) +
                  math.pow(d3.get(j), 2) + math.pow(d4.get(j), 2)) * 0.25
        out.set(i, math.sqrt(s))
    out

knnPred(dist, n) =>
    ix   = dist.sort_indices()
    useN = math.min(n, ix.size())
    sumD = 0.0
    avg  = 0.0
    for i = 0 to useN - 1
        sumD += dist.get(ix.get(i))
    if useN > 0
        for i = 0 to useN - 1
            d = dist.get(ix.get(i))
            w = useN > 1 ? (sumD != 0 ? 1.0 - d / sumD : 1.0) : 1.0
            avg += kY.get(ix.get(i)) * w
    avg

if barstate.isconfirmed and kRdy
    y_ = math.log(kBase) - math.log(kBase[_ahead])
    kF1 := pushFeat(kM1, 1)
    kF2 := pushFeat(kM2, 2)
    kF3 := pushFeat(kM3, 3)
    kF4 := pushFeat(kM4, 4)
    if kY.size() >= kMem
        kY.shift()
    kY.push(y_)
    kDs   := getDist(kF1, kF2, kF3, kF4, kM1, kM2, kM3, kM4)
    kPred := knnPred(kDs, kK)

predSm_ = ta.ema(kPred, kSmth)
if not na(kPred)
    kPredSm := kSmth > 1 ? predSm_ : kPred

hiR = kBase + _bMult * kAtr
loR = kBase - _bMult * kAtr
if ta.highest(hiR, _regLn) == hiR
    kUp := true
if ta.lowest(loR, _regLn) == loR
    kUp := false

kOsc  = ta.ema(kPredSm, _oscLn)
kSig  = ta.ema(kOsc, kSigLn)
kHist = kOsc - kSig

aiBull = ta.crossover(kOsc, kSig)  and kSig >= 0 and kUp
aiBear = ta.crossunder(kOsc, kSig) and kSig <= 0 and not kUp

// ══════════════════════════════════════════════════════════════════════════════
// 2. AUTOTUNE FILTER (Ehlers — TASC May 2026)
// ══════════════════════════════════════════════════════════════════════════════

hpf(src, p) =>
    w  = 1.414 * math.pi / p
    q  = math.exp(-w)
    c1 = 2.0 * q * math.cos(w)
    c2 = q * q
    a0 = 0.25 * (1.0 + c1 + c2)
    float res = 0.0
    if bar_index >= 4
        res := a0 * (src - 2.0 * src[1] + src[2]) + c1 * nz(res[1]) - c2 * nz(res[2])
    res

bpf(src, p, bw) =>
    w0 = 2.0 * math.pi / p
    l1 = math.cos(w0)
    g1 = math.cos(w0 * bw)
    s1 = 1.0 / g1 - math.sqrt(1.0 / (g1 * g1) - 1.0)
    float res = 0.0
    if bar_index >= 3
        res := 0.5 * (1.0 - s1) * (src - src[2]) + l1 * (1.0 + s1) * nz(res[1]) - s1 * nz(res[2])
    res

autoTune(src, wlen, bw) =>
    var array<float> atD = array.new<float>(wlen, 0.0)
    var array<float> atA = array.new<float>(wlen, 0.0)
    atMat = matrix.new<float>()
    hp    = hpf(src, wlen)
    sx    = math.sum(hp, wlen)
    sxx   = math.sum(hp * hp, wlen)
    atD.unshift(hp)
    atD.pop()
    atMat.add_row(0, atD)
    for i = 0 to wlen - 1
        lag  = i + 1
        lD   = atD[lag]
        sy   = sx[lag]
        syy  = sxx[lag]
        sxy  = na(lD) ? 0.0 : atMat.mult(lD).first()
        cov  = wlen * sxy - sx * sy
        vx   = wlen * sxx - sx * sx
        vy   = wlen * syy - sy * sy
        den  = math.sqrt(vx * vy)
        corr = den > 0 ? cov / den : 0.0
        atA.set(i, nz(corr, 1.0))
    minC = atA.min()
    dc   = (atA.indexof(minC) + 1) * 2
    dc   := nz(math.min(math.max(dc, nz(dc[1], dc) - 2), nz(dc[1], dc) + 2), dc)
    bp   = bpf(src, dc, bw)
    [hp, dc, bp]

[atHp, atDc, atBp] = autoTune(close, atWin, 0.25)

atBull = atBp > 0 and atBp > atBp[1]
atBear = atBp < 0 and atBp < atBp[1]

// ══════════════════════════════════════════════════════════════════════════════
// 3. 6-SCALE EMA CONSENSUS (SmartTrader EP06 — simplified)
// 6 pairs voting up/down — mirrors the 6 SCALES array (3,7,13,19,29,47)
// ══════════════════════════════════════════════════════════════════════════════

sc1u = ta.ema(close, 3)   > ta.ema(close, 11)
sc2u = ta.ema(close, 5)   > ta.ema(close, 15)
sc3u = ta.ema(close, 11)  > ta.ema(close, 21)
sc4u = ta.ema(close, 17)  > ta.ema(close, 27)
sc5u = ta.ema(close, 27)  > ta.ema(close, 37)
sc6u = ta.ema(close, 45)  > ta.ema(close, 55)

upCnt = (sc1u ? 1:0) + (sc2u ? 1:0) + (sc3u ? 1:0) + (sc4u ? 1:0) + (sc5u ? 1:0) + (sc6u ? 1:0)
dnCnt = 6 - upCnt

yzBull = upCnt >= yzMin
yzBear = dnCnt >= yzMin

// ══════════════════════════════════════════════════════════════════════════════
// 4. RSI MOMENTUM (Pumori / Carrrir — EMA-smoothed RSI)
// ══════════════════════════════════════════════════════════════════════════════

rsiVal = ta.rsi(close, rsiLen)
rsiEma = ta.ema(rsiVal, rsiMaL)   // ln2 iz Pumori koda

rsiBull = rsiEma > 50 and rsiEma > rsiEma[1]
rsiBear = rsiEma < 50 and rsiEma < rsiEma[1]

// ══════════════════════════════════════════════════════════════════════════════
// 5. CVD DELTA (CVDProfiles + FocusBars — simplified signed volume)
// Puna implementacija koristi lower-TF data; ovdje: bar-level signed volume
// ══════════════════════════════════════════════════════════════════════════════

barDlta = volume * math.sign(close - open)
cvdSum  = math.sum(barDlta, cvdLen)
cvdSmth = ta.ema(cvdSum, 9)

cvdBull = cvdSum > 0 and cvdSum > cvdSmth
cvdBear = cvdSum < 0 and cvdSum < cvdSmth

// ══════════════════════════════════════════════════════════════════════════════
// 6. SIGNAL COMBINATION
// ══════════════════════════════════════════════════════════════════════════════

bullCnt = (aiBull ? 1:0) + (atBull ? 1:0) + (yzBull ? 1:0) + (rsiBull ? 1:0) + (cvdBull ? 1:0)
bearCnt = (aiBear ? 1:0) + (atBear ? 1:0) + (yzBear ? 1:0) + (rsiBear ? 1:0) + (cvdBear ? 1:0)

longSig  = bullCnt >= minSig and strategy.position_size == 0
shortSig = bearCnt >= minSig and strategy.position_size == 0

// ══════════════════════════════════════════════════════════════════════════════
// 7. STRATEGY EXECUTION (SL 2% / TP 4%)
// ══════════════════════════════════════════════════════════════════════════════

if longSig
    strategy.entry("LONG", strategy.long)

if shortSig
    strategy.entry("SHORT", strategy.short)

if strategy.position_size > 0
    ep = strategy.position_avg_price
    strategy.exit("LONG-X", "LONG", stop=ep * (1 - slPct/100), limit=ep * (1 + tpPct/100))

if strategy.position_size < 0
    ep = strategy.position_avg_price
    strategy.exit("SHORT-X", "SHORT", stop=ep * (1 + slPct/100), limit=ep * (1 - tpPct/100))

// ══════════════════════════════════════════════════════════════════════════════
// 8. ALERT CONDITIONS (za bot integraciju)
// ══════════════════════════════════════════════════════════════════════════════

alertcondition(longSig,  "SYN7 LONG",  "SYNAPSE7 LONG {{ticker}} @ {{close}} | Score:{{plot_0}}")
alertcondition(shortSig, "SYN7 SHORT", "SYNAPSE7 SHORT {{ticker}} @ {{close}} | Score:{{plot_0}}")

// ══════════════════════════════════════════════════════════════════════════════
// 9. PLOTS
// ══════════════════════════════════════════════════════════════════════════════

hline(0, "Zero", color.new(chart.fg_color, 70))

colOsc = kOsc >= 0 ? color.rgb(175, 255, 105) : color.rgb(255, 71, 80)
plot(kOsc,  "AI Osc",  color=colOsc,                                    linewidth=2)
plot(kSig,  "AI Sig",  color=color.new(color.gray, 20),                 linewidth=1)
plot(kHist, "AI Hist", style=plot.style_columns,
     color=kHist >= 0 ? color.new(color.rgb(175,255,105), 35) : color.new(color.rgb(255,71,80), 35))

// AutoTune BP — normaliziran na ±0.4 skalu
atMax = ta.highest(math.abs(atBp), 100)
atNrm = atMax > 0 ? atBp / atMax * 0.4 : 0.0
plot(atNrm, "AutoTune BP", color=color.new(color.blue, 30), linewidth=1)

// Score bars
plot( bullCnt, "Bull Score", color=color.new(color.lime, 55), style=plot.style_area)
plot(-bearCnt, "Bear Score", color=color.new(color.red,  55), style=plot.style_area)

// Entry markers
plotshape(longSig,  "LONG",  shape.triangleup,   location.bottom, color.rgb(175,255,105), size=size.small)
plotshape(shortSig, "SHORT", shape.triangledown,  location.top,   color.rgb(255, 71, 80), size=size.small)

// ── Dashboard table ──────────────────────────────────────────────────────────
var table dt = table.new(position.top_right, 2, 9,
     bgcolor=#0d1117, frame_color=#30363d, frame_width=1,
     border_width=1, border_color=#21262d)

if barstate.islast
    gc = color.rgb(175, 255, 105)
    rc = color.rgb(255, 71, 80)
    mc = color.rgb(139, 148, 158)
    yc = color.rgb(255, 235, 59)

    table.cell(dt, 0, 0, "SYNAPSE-7",    text_color=color.white, bgcolor=#1f2937, text_size=size.small)
    table.cell(dt, 1, 0, syminfo.ticker, text_color=yc,          bgcolor=#1f2937, text_size=size.small)

    table.cell(dt, 0, 1, "🤖 AI kNN",    text_color=mc, text_size=size.tiny)
    table.cell(dt, 1, 1, aiBull ? "▲ BULL" : aiBear ? "▼ BEAR" : "—",
               text_color=aiBull ? gc : aiBear ? rc : mc, text_size=size.tiny)

    table.cell(dt, 0, 2, "📡 AutoTune",  text_color=mc, text_size=size.tiny)
    table.cell(dt, 1, 2, atBull ? "▲ BULL" : atBear ? "▼ BEAR" : "—",
               text_color=atBull ? gc : atBear ? rc : mc, text_size=size.tiny)

    table.cell(dt, 0, 3, "📐 6-Scale",   text_color=mc, text_size=size.tiny)
    table.cell(dt, 1, 3,
               yzBull ? "▲ " + str.tostring(upCnt) + "/6" :
               yzBear ? "▼ " + str.tostring(dnCnt) + "/6" : "◈ MIX",
               text_color=yzBull ? gc : yzBear ? rc : mc, text_size=size.tiny)

    table.cell(dt, 0, 4, "📊 RSI",       text_color=mc, text_size=size.tiny)
    table.cell(dt, 1, 4, str.tostring(math.round(rsiEma)),
               text_color=rsiBull ? gc : rsiBear ? rc : mc, text_size=size.tiny)

    table.cell(dt, 0, 5, "📦 CVD",       text_color=mc, text_size=size.tiny)
    table.cell(dt, 1, 5, cvdBull ? "▲ BUY" : cvdBear ? "▼ SELL" : "—",
               text_color=cvdBull ? gc : cvdBear ? rc : mc, text_size=size.tiny)

    table.cell(dt, 0, 6, "🎯 Score",     text_color=mc, text_size=size.tiny)
    table.cell(dt, 1, 6,
               str.tostring(bullCnt) + "↑ / " + str.tostring(bearCnt) + "↓",
               text_color=bullCnt >= minSig ? gc : bearCnt >= minSig ? rc : mc,
               text_size=size.tiny)

    table.cell(dt, 0, 7, "⏱ AutoTune DC", text_color=mc, text_size=size.tiny)
    table.cell(dt, 1, 7, str.tostring(atDc) + " bars",
               text_color=color.white, text_size=size.tiny)

    table.cell(dt, 0, 8, "⚡ SL / TP",   text_color=mc, text_size=size.tiny)
    table.cell(dt, 1, 8,
               str.tostring(slPct) + "% / " + str.tostring(tpPct) + "%",
               text_color=color.white, text_size=size.tiny)
